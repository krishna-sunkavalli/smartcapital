# --- Alpaca (market data + order execution) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# paper | live  (Phase 1 runs paper; live requires phase>=2 in config)
ALPACA_ENV=paper

# --- Fundamentals provider (Financial Modeling Prep) ---
FMP_API_KEY=

# --- Anthropic (AI analyst) ---
ANTHROPIC_API_KEY=

# --- Telegram approvals ---
TELEGRAM_BOT_TOKEN=
# The single allowlisted chat id. Messages from any other chat are dropped and logged.
TELEGRAM_ALLOWED_CHAT_ID=
# Secret used to HMAC-sign callback payloads (generate: python -c "import secrets; print(secrets.token_hex(32))")
APPROVAL_SIGNING_SECRET=

# --- Storage ---
AIIS_DATABASE_URL=sqlite:///aiis.db
